<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="top.emilejones.hhu.document.mapper.SourceDocumentMapper">

    <select id="findById" parameterType="string" resultType="top.emilejones.hhu.document.entity.SourceDocumentPO">
        SELECT id, filename, catapath, filepath, filetype
        FROM col_file
        WHERE id = #{id}
          AND isdelete = 0
          AND creator != 'OCR'
        LIMIT 1
    </select>

</mapper>
