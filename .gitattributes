# 自动检测文本文件
* text=auto

# 代码文件统一使用LF（确保跨平台一致性）
*.kt text eol=lf
*.java text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# 配置和脚本文件
*.env text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# 二进制文件明确标记
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.jar binary
*.class binary